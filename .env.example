# === DATABASE (Neon PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL_SYNC=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb

# === TELEGRAM BOT (@noticiando_pe_bot) ===
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrSTUvwxYZ1234567890
TELEGRAM_ADMIN_ID=123456789

# === CLOUDINARY (Media Storage) ===
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz123

# === HUGGING FACE (AI Inference) ===
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === NEON DB CONNECTION POOL ===
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# === RENDER ===
RENDER_EXTERNAL_URL=https://tu-app.onrender.com

# === SECURITY ===
SECRET_KEY=generar-con-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === DEFAULT ADMIN ===
ADMIN_EMAIL=admin@noticiando.pe
ADMIN_PASSWORD=changeme_secure_password

# === SCRAPER SETTINGS ===
DEFAULT_FETCH_INTERVAL=300
MAX_SCRAPER_RETRIES=5
SCRAPER_BASE_DELAY=1
PROXY_ENABLED=false
PROXY_LIST=

# === PLAYWRIGHT (para JS rendering) ===
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# === SCHEDULER ===
SCHEDULER_SOURCES_INTERVAL=5
SCHEDULER_CLEANUP_INTERVAL=1440
SCHEDULER_BACKUP_INTERVAL=43200

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FORMAT=json
